import SwiftUI

struct TranslationEntry: Identifiable {
    let id = UUID()
    let timestamp: Date
    let direction: TranslationDirection
    let original: String
    let translated: String
}

enum TranslationDirection {
    case barkToHuman
    case humanToBark
}

struct TranslationView: View {
    @StateObject private var audioRecorder = AudioRecorder()
    @StateObject private var barkSynth = BarkSynthesizer()
    @State private var engine = TranslationEngine()
    @State private var entries: [TranslationEntry] = []
    @State private var humanInput = ""
    @State private var barkSessionStart: Date?
    @State private var peakLevel: Float = 0
    @State private var timer: Timer?

    var body: some View {
        VStack(spacing: 0) {
            // Title
            Text("WoofTalk")
                .font(.largeTitle)
                .fontWeight(.bold)
                .padding(.top, 10)

            // Currently detected bark translation
            if audioRecorder.isRecording {
                Text(getCurrentBarkTranslation())
                    .font(.title3)
                    .fontWeight(.semibold)
                    .foregroundColor(.primary)
                    .padding(.vertical, 6)
                    .id(engine.lastBarkTranslation)
            }

            // Audio output indicator
            if barkSynth.isSpeaking {
                HStack(spacing: 8) {
                    Image(systemName: "speaker.wave.3.fill")
                        .foregroundColor(.green)
                    Text("Speaking...")
                        .font(.caption)
                        .foregroundColor(.green)
                }
                .padding(.vertical, 4)
                .padding(.horizontal, 12)
                .background(Color.green.opacity(0.1))
                .cornerRadius(12)
            }

            // Large bark output display for visual demo
            if !entries.isEmpty {
                let lastEntry = entries.first!
                VStack(spacing: 4) {
                    HStack(spacing: 8)

            // Recording indicator
            if audioRecorder.isRecording {
                VStack(spacing: 12) {
                    ZStack {
                        Circle()
                            .fill(Color.red.opacity(0.2))
                            .frame(width: 120, height: 120)
                        Circle()
                            .fill(Color.red.opacity(0.3))
                            .frame(width: 100, height: 100)
                            .scaleEffect(0.8 + Double(audioRecorder.audioLevel) * 0.5)
                        Circle()
                            .fill(Color.red)
                            .frame(width: 70, height: 70)
                        Image(systemName: "waveform")
                            .font(.title)
                            .foregroundColor(.white)
                    }
                    .animation(.easeInOut(duration: 0.1), value: audioRecorder.audioLevel)

                    Text("Listening for barks...")
                        .font(.subheadline)
                        .foregroundColor(.primary)
                        .fontWeight(.bold)

                    // Audio level bar
                    GeometryReader { geo in
                        ZStack(alignment: .leading) {
                            RoundedRectangle(cornerRadius: 4)
                                .fill(Color.gray.opacity(0.2))
                                .frame(height: 8)
                            RoundedRectangle(cornerRadius: 4)
                                .fill(
                                    LinearGradient(
                                        colors: [.green, .yellow, .red],
                                        startPoint: .leading,
                                        endPoint: .trailing
                                    )
                                )
                                .frame(width: geo.size.width * CGFloat(audioRecorder.audioLevel), height: 8)
                        }
                    }
                    .frame(height: 8)
                }
                .padding(.top, 10)
            } else {
                VStack(spacing: 8) {
                    Image(systemName: "speaker.wave.3")
                        .font(.system(size: 50))
                        .foregroundColor(.secondary)
                    Text("Tap Record to translate your dog's barks")
                        .foregroundColor(.secondary)
                        .multilineTextAlignment(.center)
                }
                .padding(.top, 30)
            }

            Spacer()

            // Record / Stop button
            Button(action: toggleRecording) {
                Text(audioRecorder.isRecording ? "Stop Recording" : "Record")
                    .font(.title2)
                    .fontWeight(.bold)
                    .foregroundColor(.white)
                    .frame(maxWidth: .infinity)
                    .frame(height: 55)
                    .background(audioRecorder.isRecording ? Color.red : Color.blue)
                    .cornerRadius(16)
            }
            .padding(.horizontal)
            .padding(.bottom, 4)

            // Demo bark buttons (simulator has no mic input, these let you demo the feature)
            if audioRecorder.isRecording {
                VStack(spacing: 6) {
                    Text("Simulate a bark:")
                        .font(.caption)
                        .foregroundColor(.secondary)

                    ScrollView(.horizontal, showsIndicators: false) {
                        HStack(spacing: 8) {
                            ForEach(demoBarks) { bark in
                                Button(action: {
                                    withAnimation { simulateBark(bark) }
                                }) {
                                    VStack(spacing: 2) {
                                        Text(bark.icon)
                                            .font(.system(size: 22))
                                        Text(bark.label)
                                            .font(.caption2)
                                            .fontWeight(.medium)
                                            .foregroundColor(.primary)
                                    }
                                    .frame(minWidth: 70)
                                    .padding(.vertical, 6)
                                    .background(Color.orange.opacity(0.15))
                                    .cornerRadius(10)
                                }
                            }
                        }
                    }
                }
                .padding(.horizontal)
                .padding(.bottom, 8)
            }

            // Human -> Bark button
            Button(action: {
                humanInput = ""
                showHumanInputSheet = true
            }) {
                Label(" Translate your message to Bark", systemImage: "arrow.left.arrow.right")
                    .font(.subheadline)
                    .foregroundColor(.blue)
                    .frame(maxWidth: .infinity)
                    .frame(height: 40)
                    .background(Color.blue.opacity(0.1))
                    .cornerRadius(10)
            }
            .padding(.horizontal)
            .padding(.bottom, 8)

            // Translation history
            VStack(alignment: .leading, spacing: 0) {
                HStack {
                    Text("Translation History")
                        .font(.headline)
                    Spacer()
                    if !entries.isEmpty {
                        Button("Clear") {
                            entries.removeAll()
                        }
                        .font(.caption)
                        .foregroundColor(.blue)
                    }
                }
                .padding(.bottom, 8)

                if entries.isEmpty {
                    Text("No translations yet")
                        .foregroundColor(.secondary)
                        .frame(maxWidth: .infinity, alignment: .center)
                        .padding()
                } else {
                    ScrollView {
                        LazyVStack(spacing: 8) {
                            ForEach(entries) { entry in
                                HStack {
                                    VStack(alignment: .leading, spacing: 4) {
                                        HStack(spacing: 6) {
                                            Image(systemName: entry.direction == .barkToHuman ? "dog" : "person")
                                                .font(.caption)
                                                .foregroundColor(entry.direction == .barkToHuman ? .orange : .blue)
                                            Text(entry.original)
                                                .font(.subheadline)
                                                .foregroundColor(.secondary)
                                        }
                                        Text(entry.translated)
                                            .font(.body)
                                            .fontWeight(.medium)
                                            .lineLimit(3)
                                    }
                                    Spacer()
                                    Image(systemName: entry.direction == .barkToHuman ? "arrow.right" : "arrow.left")
                                        .foregroundColor(.secondary)
                                }
                                .padding()
                                .background(Color(.systemGray6))
                                .cornerRadius(10)
                            }
                        }
                        .padding(.horizontal)
                    }
                    .frame(maxHeight: 200)
                }
            }
        }
        .padding()
        .sheet(isPresented: $showHumanInputSheet) {
            HumanInputSheet(humanInput: $humanInput, onSend: { text in
                let bark = engine.humanToBark(text)
                withAnimation {
                    entries.insert(
                        TranslationEntry(
                            timestamp: Date(),
                            direction: .humanToBark,
                            original: text,
                            translated: bark
                        ),
                        at: 0
                    )
                }
                // Play bark sound
                barkSynth.playBark(bark)
            })
        }
    }

    @State private var showHumanInputSheet = false

    private func toggleRecording() {
        if audioRecorder.isRecording {
            barkSessionStart = nil
            peakLevel = 0
            timer?.invalidate()
            timer = nil
            audioRecorder.stopRecording()
        } else {
            engine.reset()
            entries.removeAll()
            barkSessionStart = nil
            peakLevel = 0
            do {
                try audioRecorder.startRecording()
            } catch {
                print("Failed to start recording: \(error.localizedDescription)")
            }
            timer = Timer.scheduledTimer(withTimeInterval: 0.05, repeats: true) { _ in
                if audioRecorder.isRecording {
                    if audioRecorder.audioLevel > 0.15 {
                        if barkSessionStart == nil {
                            barkSessionStart = Date()
                        }
                    } else if let start = barkSessionStart {
                        let duration = Date().timeIntervalSince(start)
                        if let translation = engine.processBark(audioLevel: peakLevel, duration: duration) {
                            DispatchQueue.main.async {
                                entries.insert(
                                    TranslationEntry(
                                        timestamp: Date(),
                                        direction: .barkToHuman,
                                        original: "Bark (\(String(format: "%.1f", duration))s)",
                                        translated: translation
                                    ),
                                    at: 0
                                )
                            }
                        }
                        peakLevel = 0
                        barkSessionStart = nil
                    }
                    peakLevel = max(peakLevel, audioRecorder.audioLevel)
                }
            }
        }
    }

    // Demo: simulate bark events for showcase (simulator has no real mic input)
    private struct DemoBark: Identifiable {
        let id = UUID()
        let duration: TimeInterval
        let level: Float
        let label: String
        let icon: String
        let humanMeaning: String
    }

    private let demoBarks: [DemoBark] = [
        DemoBark(duration: 0.15, level: 0.7, label: "Short Bark", icon: "🐕", humanMeaning: "Hey!"),
        DemoBark(duration: 0.4, level: 0.5, label: "Double Bark", icon: "🐶", humanMeaning: "Play with me!"),
        DemoBark(duration: 1.5, level: 0.3, label: "Whine", icon: "🥺", humanMeaning: "I'm worried..."),
        DemoBark(duration: 1.8, level: 0.8, label: "Growl", icon: "😤", humanMeaning: "Back off!"),
        DemoBark(duration: 3.0, level: 0.7, label: "Howl", icon: "🐺", humanMeaning: "Where are you?"),
    ]

    private func simulateBark(_ bark: DemoBark) {
        audioRecorder.isRecording = true
        withAnimation(.spring()) {
            audioRecorder.audioLevel = bark.level
        }

        if let translation = engine.processBark(audioLevel: bark.level, duration: bark.duration) {
            withAnimation {
                engine.lastBarkTranslation = translation
                entries.insert(
                    TranslationEntry(
                        timestamp: Date(),
                        direction: .barkToHuman,
                        original: "\(bark.icon) \(bark.label) (\(String(format: "%.1f", bark.duration))s)",
                        translated: translation
                    ),
                    at: 0
                )
            }
            // Speak the human translation aloud
            barkSynth.speakTranslation(translation)
        }

        DispatchQueue.main.asyncAfter(deadline: .now() + 1.2) {
            withAnimation {
                audioRecorder.audioLevel = 0.0
            }
        }
    }

    private func getCurrentBarkTranslation() -> String {
        if let translation = engine.lastBarkTranslation {
            return translation
        }
        if audioRecorder.audioLevel > 0.15 {
            return "Detecting bark..."
        }
        return "Listening for barks..."
    }
}

// MARK: - Human Input Sheet

struct HumanInputSheet: View {
    @Binding var humanInput: String
    @Environment(\.dismiss) var dismiss
    let onSend: (String) -> Void

    var body: some View {
        NavigationView {
            VStack(spacing: 16) {
                Image(systemName: "person.fill")
                    .font(.system(size: 40))
                    .foregroundColor(.blue)

                Text("What do you want to say to your dog?")
                    .font(.headline)

                TextField("e.g., Hello, good boy, walk...", text: $humanInput)
                    .textFieldStyle(.roundedBorder)
                    .padding(.horizontal)

                Spacer()
            }
            .padding()
            .navigationTitle("Human to Bark")
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .topBarLeading) {
                    Button("Cancel") { dismiss() }
                }
                ToolbarItem(placement: .topBarTrailing) {
                    Button("Translate") {
                        let text = humanInput.trimmingCharacters(in: .whitespacesAndNewlines)
                        guard !text.isEmpty else { return }
                        onSend(text)
                        humanInput = ""
                        dismiss()
                    }
                    .fontWeight(.bold)
                }
            }
            .confirmationDialog("", isPresented: .constant(false), titleVisibility: .hidden, actions: {})
        }
    }
}

#Preview {
    TranslationView()
}
